# Python 缓存
__pycache__/
*.py[cod]
*.pyo

# 虚拟环境
.venv*/
venv/

# 环境变量（含 API Key，绝不提交）
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# 密钥文件
backend/data/app_secret.txt
*.pem
*.key
*.crt
*.p12
*.pfx

# 数据库（本地开发数据，不提交）
*.db
*.sqlite
*.sqlite3
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3

# 备份 / 导出 / 临时文件
*.bak
*.backup
*.tmp
*.swp
*.orig
*.csv
*.xlsx
*.zip

# 系统文件
.DS_Store
Thumbs.db

# IDE / 编辑器
.vscode/
.idea/

# 日志
logs/
*.log

# Playwright 测试临时产物
.playwright-cli/

# 用户上传的头像（运行时生成）
avatars/
!avatars/.gitkeep

# 部署产物
*.tar.gz
backups/

# 服务器配置（含密码，绝不提交）
.server_config

# 审计报告（临时产物）
AI_Friend_代码审计报告.docx

# Skills 安装产物
.agents/
skills-lock.json

# AI 编程工具配置目录（各工具打开项目时自动创建，无需提交）
