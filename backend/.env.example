# ============================================================
# AIFriend 环境配置模板
#
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 填写你的实际配置值
#   3. 所有带 🔴 标记的为必需配置项
#
# 安全说明：
#   - .env 文件包含敏感信息，请勿提交到 Git
#   - APP_SECRET 优先从环境变量 APP_SECRET 读取，其次从 data/app_secret.txt
#     文件读取；首次运行时会自动生成随机密钥并持久化到文件
#   - 生产环境务必设置 ENV=production 且 DEBUG=false
# ============================================================


# ============================================================
# 🔴 环境与调试模式（必需）
# ============================================================
# ENV: development | production
#   生产环境必须设为 production
ENV=production

# DEBUG: true | false
#   生产环境必须设为 false（开启后会暴露错误详情到前端）
DEBUG=false


# ============================================================
# 🔴 数据库配置（必需）
# ============================================================
# Supabase PostgreSQL 连接字符串
# 类型：string
# 格式：postgresql://postgres:[密码]@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.supabase.co:5432/postgres

# 数据库连接池大小（已针对 Supabase PgBouncer 优化）
# PgBouncer 已在服务端做连接池化，客户端只需少量常驻连接
# DB_POOL_MIN_CONN: 最小连接数，类型 int，默认 2，范围 1-20
# DB_POOL_MAX_CONN: 最大连接数，类型 int，默认 5，范围 3-50
#   ⚠️ 多个 uvicorn worker 会各自创建连接池：总连接数 = max_conn × workers
#   Supabase Free 仅支持 15 连接，Pro 支持 200
#   建议：max_conn × workers ≤ PgBouncer 上限的 50%
# DB_POOL_MIN_CONN=2
# DB_POOL_MAX_CONN=5


# ============================================================
# 🔴 AI 模型配置（必需）
# ============================================================
# 主模型 API Key（OpenAI 兼容协议）
# 类型：string，示例：sk-xxxxx
AIFRIEND_API_KEY=sk-your-api-key-here

# 模型 Base URL（OpenAI 兼容端点）
# 类型：string（URL），默认：https://realmrouter.cn/v1
AIFRIEND_BASE_URL=https://realmrouter.cn/v1

# 模型名称
# 类型：string，默认：glm-5.1
AIFRIEND_MODEL=glm-5.1

# 模型生成参数（可选，影响 AI 回复风格）
# AIFRIEND_TEMPERATURE: 控制创造性，类型 float，推荐 0.7-0.9，默认 0.9
# AIFRIEND_TOP_P: 控制输出多样性，类型 float，推荐 0.9
# AIFRIEND_TEMPERATURE=0.9
# AIFRIEND_TOP_P=0.9


# ============================================================
# 🔴 CORS 跨域配置（必需）
# ============================================================
# 允许的域名，多个用英文逗号分隔
# 类型：string
# 示例：https://yourdomain.com,https://www.yourdomain.com
# 注意：生产环境禁止使用 localhost，配合 credentials: include 会导致 CSRF 风险
ALLOWED_ORIGINS=https://yourdomain.com


# ============================================================
# 🔴 邮件服务配置（必需，用于发送密码重置验证码）
# ============================================================
# 方式一：SMTP（推荐，QQ 邮箱可发到任意邮箱）
#   获取 SMTP 授权码：QQ邮箱 → 设置 → 账户 → 开启 SMTP → 手机验证获取授权码
# SMTP_HOST: 类型 string，示例 smtp.qq.com
# SMTP_PORT: 类型 int，示例 465 (SSL) 或 587 (STARTTLS)
# SMTP_USER: 类型 string，示例 your_email@qq.com
# SMTP_PASSWORD: 类型 string（SMTP 授权码，非邮箱密码）
# SMTP_FROM: 类型 string，发件人显示名称和地址
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=AI Friend <your_email@qq.com>

# 方式二：Resend API（备选，免费版只能发到绑定邮箱）
# RESEND_API_KEY: 类型 string，示例 re_xxxxx
# 两种方式二选一，都填则优先使用 Resend
# RESEND_API_KEY=re_your_resend_api_key_here


# ============================================================
# 🔴 管理员配置（必需）
# ============================================================
# 管理后台邮箱白名单，多个用英文逗号分隔
# 类型：string，示例：admin@example.com,admin2@example.com
ADMIN_EMAILS=admin@example.com


# ============================================================
# 🟡 Token 与认证配置
# ============================================================
# Access Token 有效期（分钟）
# 类型：int，默认 15，范围 5-60
# 短期 access token 用于 API 鉴权，通过 HttpOnly Cookie 发送
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token 有效期（天）
# 类型：int，默认 30，范围 1-365
# 长期 refresh token 用于续期 access token，绑定设备指纹
REFRESH_TOKEN_EXPIRE_DAYS=30

# 旧版 Token 有效期（天），向后兼容
# 类型：int，默认 30，范围 1-365
# TOKEN_EXPIRE_DAYS=30


# ============================================================
# 🟡 限流配置
# ============================================================
# --- 登录限流 ---
# LOGIN_RATE_LIMIT_COUNT: 同一 IP 时间窗口内最大登录次数，类型 int，默认 15
# LOGIN_RATE_LIMIT_WINDOW_SECONDS: 时间窗口（秒），类型 int，默认 600
# LOGIN_RATE_LIMIT_EMAIL_COUNT: 同一邮箱时间窗口内最大登录次数，类型 int，默认 10
# LOGIN_RATE_LIMIT_COUNT=15
# LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
# LOGIN_RATE_LIMIT_EMAIL_COUNT=10

# --- 注册限流 ---
# REGISTER_RATE_LIMIT_COUNT: 同一 IP 时间窗口内最大注册次数，类型 int，默认 6
# REGISTER_RATE_LIMIT_WINDOW_SECONDS: 时间窗口（秒），类型 int，默认 3600
# REGISTER_RATE_LIMIT_COUNT=6
# REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600

# --- 密码重置限流 ---
# PASSWORD_RESET_RATE_LIMIT_COUNT: 同一 IP 时间窗口内最大请求次数，类型 int，默认 5
# PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS: 时间窗口（秒），类型 int，默认 1800
# PASSWORD_RESET_RATE_LIMIT_COUNT=5
# PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=1800

# --- 验证码校验限流 ---
# VERIFY_CODE_RATE_LIMIT_COUNT: 同一 IP 时间窗口内最大校验次数，类型 int，默认 12
# VERIFY_CODE_RATE_LIMIT_WINDOW_SECONDS: 时间窗口（秒），类型 int，默认 600
# VERIFY_CODE_RATE_LIMIT_COUNT=12
# VERIFY_CODE_RATE_LIMIT_WINDOW_SECONDS=600

# --- 已登录聊天限流 ---
# CHAT_RATE_LIMIT_COUNT: 同一用户时间窗口内最大聊天请求次数，类型 int，默认 45
# CHAT_RATE_LIMIT_WINDOW_SECONDS: 时间窗口（秒），类型 int，默认 60
# CHAT_RATE_LIMIT_COUNT=45
# CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# --- 游客试聊限流 ---
# GUEST_CHAT_RATE_LIMIT_COUNT: 同一 IP 时间窗口内最大游客请求次数，类型 int，默认 12
# GUEST_CHAT_RATE_LIMIT_WINDOW_SECONDS: 时间窗口（秒），类型 int，默认 600
# GUEST_CHAT_RATE_LIMIT_COUNT=12
# GUEST_CHAT_RATE_LIMIT_WINDOW_SECONDS=600


# ============================================================
# 🟢 成本防护配置
# ============================================================
# 单次聊天最大输出 token（限制单轮回复成本）
# 类型：int，默认 768，范围 64-4096
AI_CHAT_MAX_OUTPUT_TOKENS=768

# 用户每日 token 限额
# 类型：int
FREE_DAILY_TOKEN_LIMIT=180000    # 免费注册用户，默认 180000
GUEST_DAILY_TOKEN_LIMIT=40000    # 游客（按 IP），默认 40000
VIP_DAILY_TOKEN_LIMIT=450000     # VIP 用户，默认 450000
SVIP_DAILY_TOKEN_LIMIT=900000    # SVIP 用户，默认 900000

# 待支付订单有效期（分钟），超时自动关闭
# 类型：int，默认 30，范围 5-1440
BILLING_PENDING_EXPIRE_MINUTES=30

# 请求日志保留天数
# 类型：int，默认 30，范围 1-365
AI_REQUEST_LOG_RETENTION_DAYS=30


# ============================================================
# 🟢 会员产品参数
# ============================================================
# VIP 价格（分），默认 2990 = ¥29.90
# 类型：int
VIP_PLAN_PRICE_CENTS=2990

# SVIP 价格（分），默认 5990 = ¥59.90
# 类型：int
SVIP_PLAN_PRICE_CENTS=5990

# VIP 有效天数，类型 int，默认 30
VIP_PLAN_DURATION_DAYS=30

# SVIP 有效天数，类型 int，默认 30
SVIP_PLAN_DURATION_DAYS=30


# ============================================================
# 🟢 三套模型策略（可选，高级配置）
# 不填则自动回退到通用 AIFRIEND_API_KEY/BASE_URL/MODEL
# 示例值仅供参考，请替换为你的实际模型配置
# ============================================================
# AIFRIEND_BASIC_API_KEY=
# AIFRIEND_BASIC_BASE_URL=
# AIFRIEND_BASIC_MODEL=

# AIFRIEND_VIP_API_KEY=
# AIFRIEND_VIP_BASE_URL=
# AIFRIEND_VIP_MODEL=

# AIFRIEND_SVIP_API_KEY=
# AIFRIEND_SVIP_BASE_URL=
# AIFRIEND_SVIP_MODEL=


# ============================================================
# 📋 上线前检查清单
# ============================================================
# [ ] DATABASE_URL 已修改为正确的 Supabase 连接字符串
# [ ] AIFRIEND_API_KEY 已设置为有效的 API Key
# [ ] 邮件服务已配置（SMTP 推荐或 Resend API 二选一）
# [ ] ALLOWED_ORIGINS 已修改为真实域名（禁止使用 * 通配符）
# [ ] ADMIN_EMAILS 已设置管理员邮箱
# [ ] ENV=production 且 DEBUG=false
# [ ] .env 文件已添加到 .gitignore
# [ ] 限流参数已根据实际需求调整
# ============================================================
