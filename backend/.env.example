# ============================================================
# AIFriend 生产环境配置示例
# 警告：请勿在此文件中包含真实密钥！此文件会被提交到 Git！
# ============================================================

# ============================================================
# 🔴 环境与调试模式（必需）
# ============================================================
ENV=production
DEBUG=false

# ============================================================
# 🔴 数据库配置（Supabase）
# ============================================================
# ⚠️ 请修改：将下面的连接字符串替换为你的 Supabase 连接信息
# 格式：postgresql://postgres:[密码]@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.supabase.co:5432/postgres

# ============================================================
# 🔴 AI 模型配置（必需）
# ============================================================
# MiniMax API 配置
AIFRIEND_API_KEY=sk-api-your-api-key-here
AIFRIEND_BASE_URL=https://api.minimaxi.com/v1
AIFRIEND_MODEL=MiniMax-M2.7

# ============================================================
# 🔴 CORS 跨域配置（必需）
# ============================================================
# ⚠️ 当前使用服务器 IP，购买域名后请修改为真实域名
# 示例：ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# ============================================================
# 🔴 邮件服务配置（用于发送验证码）
# ============================================================
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================
# 🔴 管理员配置（必需）
# ============================================================
ADMIN_EMAILS=admin@example.com

# ============================================================
# 🟡 登录与限流配置（宽松模式）
# ============================================================
# 登录态有效期（天）
TOKEN_EXPIRE_DAYS=30

# 登录接口限流：10 分钟内最多 30 次（宽松）
LOGIN_RATE_LIMIT_COUNT=30
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600

# 已登录聊天接口限流：60 秒内最多 60 次（宽松）
CHAT_RATE_LIMIT_COUNT=60
CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# 游客试聊接口限流：10 分钟内最多 20 次（宽松）
GUEST_CHAT_RATE_LIMIT_COUNT=20
GUEST_CHAT_RATE_LIMIT_WINDOW_SECONDS=600

# ============================================================
# 🟢 成本防护配置
# ============================================================
# 单次最大输出 token
AI_CHAT_MAX_OUTPUT_TOKENS=768

# 用户每日 token 限额
FREE_DAILY_TOKEN_LIMIT=180000
GUEST_DAILY_TOKEN_LIMIT=40000
VIP_DAILY_TOKEN_LIMIT=450000
SVIP_DAILY_TOKEN_LIMIT=900000

# ============================================================
# 🟢 会员产品参数
# ============================================================
VIP_PLAN_PRICE_CENTS=2990
SVIP_PLAN_PRICE_CENTS=5990
VIP_PLAN_DURATION_DAYS=30
SVIP_PLAN_DURATION_DAYS=30

# ============================================================
# 🟢 日志与监控
# ============================================================
AI_REQUEST_LOG_RETENTION_DAYS=30

# ============================================================
# 🟢 三套模型策略（可选，高级配置）
# 不填则自动回退到通用配置
# ============================================================
AIFRIEND_BASIC_API_KEY=
AIFRIEND_BASIC_BASE_URL=
AIFRIEND_BASIC_MODEL=

AIFRIEND_VIP_API_KEY=
AIFRIEND_VIP_BASE_URL=
AIFRIEND_VIP_MODEL=

AIFRIEND_SVIP_API_KEY=
AIFRIEND_SVIP_BASE_URL=
AIFRIEND_SVIP_MODEL=

# ============================================================
# 📋 上线前检查清单
# ============================================================
# [ ] DATABASE_URL 已修改为正确的 Supabase 连接字符串
# [ ] AIFRIEND_API_KEY 已设置为有效的 MiniMax API Key
# [ ] RESEND_API_KEY 已设置为有效的 Resend API Key
# [ ] ALLOWED_ORIGINS 已修改为真实域名（或保持 * 允许所有）
# [ ] ADMIN_EMAILS 是你的管理员邮箱
# [ ] 限流参数已根据实际需求调整（当前为宽松模式）
# [ ] .env 文件已添加到 .gitignore
# ============================================================
