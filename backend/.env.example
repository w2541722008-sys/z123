# ============================================================
# aifriend 后端环境变量配置模板
# 复制为 .env 并填入真实值再启动
# ============================================================

# MiniMax AI API 配置（国内版 minimaxi.com）
# 如果你暂时只想配一套模型，先填下面这组通用回退配置即可
AIFRIEND_API_KEY=your_minimax_api_key_here
AIFRIEND_BASE_URL=https://api.minimaxi.com/v1
AIFRIEND_MODEL=MiniMax-M2.5

# 三套模型策略（推荐后期按档位分别配置）
# basic：游客 + 注册免费用户
AIFRIEND_BASIC_API_KEY=
AIFRIEND_BASIC_BASE_URL=
AIFRIEND_BASIC_MODEL=

# vip：VIP 用户用的中高端模型
AIFRIEND_VIP_API_KEY=
AIFRIEND_VIP_BASE_URL=
AIFRIEND_VIP_MODEL=

# svip：SVIP 用户用的旗舰模型
AIFRIEND_SVIP_API_KEY=
AIFRIEND_SVIP_BASE_URL=
AIFRIEND_SVIP_MODEL=

# 如果使用 OpenAI 兼容接口，填入对应配置即可
# AIFRIEND_API_KEY=sk-CfxFa2v0czwyyJQp6xBE0IjX8QbTIJ8rLKzuNZlNdwaiUUAT
# AIFRIEND_BASE_URL=https://xinyuanai666.com
# AIFRIEND_MODEL=grok-4.1

# ============================================================
# 跨域（CORS）配置
# ============================================================
# 允许访问后端 API 的前端域名列表，用英文逗号分隔
# 开发环境（本机调试）：
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# 上线后改为你的真实域名，例如：
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com

# ============================================================
# 认证与基础限流（可选）
# ============================================================
# 管理后台管理员邮箱白名单，多个邮箱用英文逗号分隔
ADMIN_EMAILS=773682014@qq.com

# 登录态有效期，单位：天
TOKEN_EXPIRE_DAYS=30

# 登录接口限流：10 分钟内最多 15 次
LOGIN_RATE_LIMIT_COUNT=15
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600

# 已登录聊天接口限流：60 秒内最多 45 次
CHAT_RATE_LIMIT_COUNT=45
CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# 游客试聊接口限流：10 分钟内最多 12 次
GUEST_CHAT_RATE_LIMIT_COUNT=12
GUEST_CHAT_RATE_LIMIT_WINDOW_SECONDS=600

# ============================================================
# 成本防护（可选）
# ============================================================
# 单次最大输出 token（越大越贵）
AI_CHAT_MAX_OUTPUT_TOKENS=768

# 注册免费用户每天最多消耗多少估算 token
FREE_DAILY_TOKEN_LIMIT=180000

# 游客每天最多消耗多少估算 token
GUEST_DAILY_TOKEN_LIMIT=40000

# VIP / SVIP 每日预算
VIP_DAILY_TOKEN_LIMIT=450000
SVIP_DAILY_TOKEN_LIMIT=900000

# AI 请求日志保留天数
AI_REQUEST_LOG_RETENTION_DAYS=30

# ============================================================
# 会员产品参数（网页支付预留）
# ============================================================
VIP_PLAN_PRICE_CENTS=2990
SVIP_PLAN_PRICE_CENTS=5990
VIP_PLAN_DURATION_DAYS=30
SVIP_PLAN_DURATION_DAYS=30
